# Copia para `.env.local` (não é commitado) e preenche os valores.
# Nunca coloques chaves reais neste ficheiro nem commits `.env.local` — só placeholders aqui; segredos vão para `.env.local` e para Vercel → Environment Variables.

# Painel /admin — senha de acesso e segredo para assinar o cookie de sessão (servidor apenas).
# ADMIN_SESSION_SECRET: mínimo 16 caracteres; use um valor aleatório longo (não reutilize a senha literal como segredo em produção).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Royal Banking — Cash In (Pix). A chave NUNCA vai para o browser.
ROYALBANKING_API_KEY=

# URL pública HTTPS que a Royal Banking pode chamar (webhook), ex.:
# https://seudominio.com/api/webhooks/royalbanking/pix
# Em local, use um túnel (ngrok) — localhost não recebe POST da gateway.
ROYALBANKING_PIX_CALLBACK_URL=

# Origem pública do site (sem barra final). Na Vercel define também para montar o webhook do Pix.
# Ex.: https://camisa-brasil-landing.vercel.app
SITE_URL=

# Base pública do site (uma delas basta). SITE_URL/APP_URL são só servidor e valem no próximo deploy.
# NEXT_PUBLIC_APP_URL exige novo build depois de definida na Vercel.
SITE_URL=
APP_URL=
NEXT_PUBLIC_APP_URL=

# Supabase — URL e chave anónima (browser / servidor). Ver Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Referência do projeto (o subdomínio de https://SEU_REF.supabase.co). Usada pelo MCP do Cursor (`.cursor/mcp.json`).
# O Cursor interpola ${env:SUPABASE_PROJECT_REF}: define esta variável no Windows (Variáveis de ambiente do utilizador)
# ou exporta no terminal antes de abrir o Cursor; o `.env.local` por vezes não é aplicado ao processo MCP.
SUPABASE_PROJECT_REF=

# Só servidor — necessária para gravar pedidos “cartão pendente” no checkout e outras escritas com RLS fechado.
# Nunca uses NEXT_PUBLIC_* com esta chave.
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Clarity — ID público (heatmaps/recording). Sobrescreve o default do código se definido.
NEXT_PUBLIC_CLARITY_ID=

# Meta (Facebook) Pixel — ID numérico do Events Manager. Opcional: o layout usa 867703813018108 se vazio.
# Purchase só dispara na página /pos-compra/obrigado após confirmação de Pix (Mangofy) no mesmo fluxo.
NEXT_PUBLIC_META_PIXEL_ID=

# UTMify
# Chave da API para postbacks server-side (não expor no browser).
UTMIFY_API_KEY=
# Endpoint de conversão/postback da UTMify (fornecido no painel/documentação).
UTMIFY_ENDPOINT=
# URL para back redirect no botão voltar (script aplicado na home).
# Ex.: https://meubackredirect.com.br
NEXT_PUBLIC_UTMIFY_BACK_REDIRECT_URL=

# Segurança opcional do webhook Royal (se preenchido, exige header no webhook):
# x-webhook-secret: <valor>  (ou Authorization: Bearer <valor>)
ROYALBANKING_WEBHOOK_SECRET=
